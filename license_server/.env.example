LICENSE_ADMIN_SECRET=change-this-to-a-long-random-string
LICENSE_HMAC_SECRET=change-this-to-another-long-random-string
LICENSE_DB=/data/license.db
LICENSE_PORT=7443
TRIAL_DAYS=30

# SMTP — required for automatic key delivery emails
# Gmail example: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@ki-honeypot.de

# Where admin notifications go (new trial signups)
NOTIFY_EMAIL=info@ki-honeypot.de
